{
  "name": "xray-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:run": "bun run scripts/run-prisma-migrate.ts",
    "db:migrate:check": "bun run scripts/check-direct-url-for-prisma-migrate.ts",
    "db:bootstrap:admins": "bun run scripts/bootstrap-app-role-admins.ts",
    "db:supabase-parity": "prisma db execute --schema prisma/schema.prisma --file scripts/supabase-parity.sql",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:upsert:backlog-vendors": "bun run scripts/upsert-backlog-vendors.ts",
    "db:ensure:backlog-instruments": "bun run scripts/ensure-backlog-instruments.ts",
    "db:backfill:nexafs-epoch": "bun run scripts/backfill-nexafs-epoch-dates.ts",
    "db:consolidate:backlog-samples": "bun run scripts/consolidate-backlog-samples-for-molecule.ts",
    "db:cleanup:samples": "bun run scripts/cleanup-samples-substrate-fingerprint.ts",
    "db:backfill:experiment-source-json": "bun run scripts/backfill-experiment-source-json.ts",
    "db:merge:itic-c94": "bun run scripts/merge-itic-molecules-c94.ts",
    "dev": "next dev --turbo",
    "dev:tunnel": "concurrently --kill-others \"next dev --turbo\" \"sleep 3 && ngrok http 3000\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1012.0",
    "@gravity-ui/icons": "^2.18.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-google-maps/api": "^2.20.8",
    "@simplewebauthn/browser": "9.0.1",
    "@simplewebauthn/server": "9.0.3",
    "@supabase/supabase-js": "^2.99.2",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.91.0",
    "@trpc/client": "^11.13.4",
    "@trpc/next": "^11.13.4",
    "@trpc/react-query": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@types/google.maps": "^3.58.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@visx/visx": "^3.12.0",
    "@visx/zoom": "^3.12.0",
    "d3": "^7.9.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dotenv": "^17.4.0",
    "lucide-react": "^0.552.0",
    "next": "^16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^22.19.15",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.13",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  }
}
