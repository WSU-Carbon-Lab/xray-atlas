{
  "name": "xray-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:upsert:backlog-vendors": "bun run scripts/upsert-backlog-vendors.ts",
    "dev": "next dev --turbo",
    "dev:tunnel": "concurrently --kill-others \"next dev --turbo\" \"sleep 3 && ngrok http 3000\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1012.0",
    "@gravity-ui/icons": "^2.18.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@heroui/badge": "^2.2.18",
    "@heroui/dropdown": "^2.3.32",
    "@heroui/navbar": "^2.2.30",
    "@heroui/pagination": "^2.2.27",
    "@heroui/react": "3.0.0-rc.1",
    "@heroui/styles": "3.0.0-rc.1",
    "@heroui/system": "^2.4.28",
    "@heroui/table": "^2.2.32",
    "@heroui/theme": "^2.4.26",
    "@prisma/client": "^6.19.2",
    "@react-google-maps/api": "^2.20.8",
    "@simplewebauthn/browser": "9.0.1",
    "@simplewebauthn/server": "9.0.3",
    "@supabase/supabase-js": "^2.99.2",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.91.0",
    "@trpc/client": "^11.13.4",
    "@trpc/next": "^11.13.4",
    "@trpc/react-query": "^11.13.4",
    "@trpc/server": "^11.13.4",
    "@types/google.maps": "^3.58.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@visx/visx": "^3.12.0",
    "@visx/zoom": "^3.12.0",
    "d3": "^7.9.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.552.0",
    "next": "^16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^22.19.15",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.13",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  }
}
