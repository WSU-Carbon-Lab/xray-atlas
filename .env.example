# X-ray Atlas Environment Variables
# Copy this file to .env.local and fill in your values
# Or use Infisical: infisical export --env=dev > .env.local

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Supabase PostgreSQL connection strings
# Get these from your Supabase project settings > Database
#
# Prisma 7: the CLI loads these via prisma.config.ts (root .env then .env.local).
# Runtime queries use DATABASE_URL through src/env.js and @prisma/adapter-pg.

# Pooled connection (for Prisma queries). Use the `prisma` database user when that role is provisioned.
DATABASE_URL="postgresql://prisma.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for Prisma migrate / db push). Prisma uses this via prisma.config.ts `datasource.url`.
# Host must be `db.<project-ref>.supabase.co` (direct) or `aws-*-<region>.pooler.supabase.com` (session pooler on 5432).
# Invalid: `aws-*-<region>.supabase.com` without `pooler` (DNS NXDOMAIN). Add `?sslmode=require&connect_timeout=30`.
DIRECT_URL="postgresql://prisma.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require&connect_timeout=30"

# Optional: comma-separated emails and/or ORCIDs for `bun run db:bootstrap:admins` after migrations.
# ADMIN_BOOTSTRAP_EMAILS="maintainer1@example.com,maintainer2@example.com"
# ADMIN_BOOTSTRAP_ORCIDS="0000-0002-1825-0097"

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get these from your Supabase project settings > API

SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Set to your ngrok URL when testing OAuth locally
# For production, set to your domain (e.g., https://xrayatlas.wsu.edu)
AUTH_URL="http://localhost:3000"

# WebAuthn / passkeys (optional; default to AUTH_URL hostname and origin)
# WEBAUTHN_RP_ID="localhost"
# WEBAUTHN_ORIGIN="http://localhost:3000"

# =============================================================================
# ORCID OAUTH (Optional - Required for ORCID sign-in)
# =============================================================================
# Register at: https://orcid.org/developer-tools
# Callback URL: {AUTH_URL}/api/auth/callback/orcid

ORCID_CLIENT_ID=""
ORCID_CLIENT_SECRET=""

# Set to "true" to use ORCID sandbox for testing
# Register sandbox app at: https://sandbox.orcid.org/developer-tools
ORCID_USE_SANDBOX="false"

# =============================================================================
# GITHUB OAUTH (Optional - Required for GitHub sign-in)
# =============================================================================
# Create OAuth App at: https://github.com/settings/developers
# Callback URL: {AUTH_URL}/api/auth/callback/github

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Local development: when set, NextAuth uses these instead of GITHUB_* in NODE_ENV=development.
# Sign in with ORCID first to create your user row, then link GitHub from your profile.
DEV_GITHUB_CLIENT_ID=""
DEV_GITHUB_CLIENT_SECRET=""

# =============================================================================
# EXTERNAL APIS (Required)
# =============================================================================
# CAS Common Chemistry API
# Register at: https://commonchemistry.cas.org/api

CAS_API_KEY=""

# =============================================================================
# ZENODO DATASET DOI MINTING (Optional)
# =============================================================================
# Per-dataset DOI minting via the Atlas repository depositor account.
# Minting is disabled when ZENODO_ACCESS_TOKEN is unset (safe for local/dev).
#
# Production community (done): https://zenodo.org/communities/xrayatlas
# Create a personal access token with scopes deposit:write + deposit:actions.
# Sandbox requires a separate account, community, and token on
# https://sandbox.zenodo.org (DOI prefix 10.5072).
#
# ZENODO_CLIENT_ID / ZENODO_CLIENT_SECRET are reserved for optional Phase 2
# per-user OAuth; v1 minting uses ZENODO_ACCESS_TOKEN only.

# ZENODO_ACCESS_TOKEN=""
# ZENODO_CLIENT_ID=""
# ZENODO_CLIENT_SECRET=""
# ZENODO_USE_SANDBOX="true"
# ZENODO_COMMUNITY_ID="xrayatlas"
#
# Optional override for the canonical Atlas origin embedded in Zenodo descriptions.
# Defaults to brand site.url (https://xrayatlas.wsu.edu). Must not be localhost.
# Preview/Vercel hosts are never used unless you set this explicitly.
# ATLAS_PUBLIC_SITE_URL="https://xrayatlas.wsu.edu"
#
# Repair published deposits that still contain localhost browse URLs:
#   bun scripts/repair-zenodo-localhost-urls.ts --dry-run
#   bun scripts/repair-zenodo-localhost-urls.ts

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Google Maps API (for facility locations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
