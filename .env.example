# X-ray Atlas Environment Variables
# Copy this file to .env.local and fill in your values
# Or use Infisical: infisical export --env=dev > .env.local

# =============================================================================
# DATABASE (Required)
# =============================================================================
# Supabase PostgreSQL connection strings
# Get these from your Supabase project settings > Database
#
# Prisma 7: the CLI loads these via prisma.config.ts (root .env then .env.local).
# Runtime queries use DATABASE_URL through src/env.js and @prisma/adapter-pg.

# Pooled connection (for Prisma queries)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (for Prisma migrate / db push). Prisma uses this via prisma.config.ts `directUrl`.
# Use the URI from Supabase: Project Settings > Database > Connection string > URI (direct), host like
# `db.<project-ref>.supabase.co` on port 5432. If migrate deploy stalls, you are often on the pooler;
# switch DIRECT_URL to that direct host and add `?sslmode=require&connect_timeout=30`.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require&connect_timeout=30"

# Optional: comma-separated emails and/or ORCIDs for `bun run db:bootstrap:admins` after migrations.
# ADMIN_BOOTSTRAP_EMAILS="maintainer1@example.com,maintainer2@example.com"
# ADMIN_BOOTSTRAP_ORCIDS="0000-0002-1825-0097"

# =============================================================================
# SUPABASE (Required)
# =============================================================================
# Get these from your Supabase project settings > API

SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Set to your ngrok URL when testing OAuth locally
# For production, set to your domain (e.g., https://xrayatlas.wsu.edu)
AUTH_URL="http://localhost:3000"

# =============================================================================
# ORCID OAUTH (Optional - Required for ORCID sign-in)
# =============================================================================
# Register at: https://orcid.org/developer-tools
# Callback URL: {AUTH_URL}/api/auth/callback/orcid

ORCID_CLIENT_ID=""
ORCID_CLIENT_SECRET=""

# Set to "true" to use ORCID sandbox for testing
# Register sandbox app at: https://sandbox.orcid.org/developer-tools
ORCID_USE_SANDBOX="false"

# =============================================================================
# GITHUB OAUTH (Optional - Required for GitHub sign-in)
# =============================================================================
# Create OAuth App at: https://github.com/settings/developers
# Callback URL: {AUTH_URL}/api/auth/callback/github

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Separate credentials for development (optional)
DEV_GITHUB_CLIENT_ID=""
DEV_GITHUB_CLIENT_SECRET=""

# =============================================================================
# HUGGING FACE OAUTH (Optional)
# =============================================================================
# Create OAuth App at: https://huggingface.co/settings/applications

HUGGINGFACE_CLIENT_ID=""
HUGGINGFACE_CLIENT_SECRET=""

# =============================================================================
# EXTERNAL APIS (Required)
# =============================================================================
# CAS Common Chemistry API
# Register at: https://commonchemistry.cas.org/api

CAS_API_KEY=""

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Google Maps API (for facility locations)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
