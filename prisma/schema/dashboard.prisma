enum DashboardProcessingSessionStatus {
  draft
  processing
  ready
  archived

  @@schema("public")
}

model dashboardprocessingsession {
  id                  String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userid              String                           @map("user_id") @db.VarChar(19)
  instrumentslug      String                           @map("instrument_slug")
  linkedexperimentid  String?                          @map("linked_experiment_id") @db.Uuid
  title               String?
  status              DashboardProcessingSessionStatus @default(draft)
  stepmetadata        Json                             @default("{}") @map("step_metadata")
  createdat           DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedat           DateTime                         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                user                             @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  linkedexperiment    experiments?                     @relation(fields: [linkedexperimentid], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userid], map: "idx_dashboard_processing_session_user_id")
  @@index([userid, updatedat(sort: Desc)], map: "idx_dashboard_processing_session_user_updated")
  @@index([linkedexperimentid], map: "idx_dashboard_processing_session_linked_experiment")
  @@map("dashboard_processing_session")
  @@schema("public")
}
