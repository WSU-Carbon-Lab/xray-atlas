model attributionteam {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  description           String?
  ownerid               String                  @map("owner_id") @db.VarChar(19)
  createdat             DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedat             DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  institution           String?
  researchgroupname     String?                 @map("research_group_name")
  grouptype             String                  @default("beamtime") @map("group_type")
  piorcidid             String?                 @map("pi_orcid_id") @db.VarChar(19)
  experimentleadorcidid String?                 @map("experiment_lead_orcid_id") @db.VarChar(19)
  members               attributionteammember[]
  owner                 user                    @relation(fields: [ownerid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ownerid], map: "idx_attribution_team_owner_id")
  @@map("attribution_team")
  @@schema("public")
}

model attributionteammember {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamid          String          @map("team_id") @db.Uuid
  orcidid         String          @map("orcid_id") @db.VarChar(19)
  userid          String?         @map("user_id") @db.VarChar(19)
  displayname     String?         @map("display_name")
  contributortype String          @map("contributor_type")
  createdat       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedat       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  team            attributionteam @relation(fields: [teamid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            user?           @relation(fields: [userid], references: [id], onUpdate: NoAction)

  @@unique([teamid, orcidid, contributortype], map: "attribution_team_member_unique_role")
  @@index([teamid], map: "idx_attribution_team_member_team_id")
  @@index([orcidid], map: "idx_attribution_team_member_orcid_id")
  @@map("attribution_team_member")
  @@schema("public")
}
